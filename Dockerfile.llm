# ─── Local LLM sidecar — llama.cpp server (OpenAI-compatible API) ──────
#
# Uses the official pre-built llama.cpp server image from GitHub Container
# Registry.  NO compilation needed — pulls and runs in seconds.
#
# Serves a GGUF model at http://localhost:8081/v1 with the same chat/completions
# API shape as OpenAI.
#
# Run via docker compose:
#   docker compose --profile llm up -d
#
# Run standalone:
#   docker run --rm -v ./models:/models -p 8081:8080 ghcr.io/ggml-org/llama.cpp:server \
#       --model /models/model.gguf --alias local --ctx-size 4096 --host 0.0.0.0
#
# Pre-download a model into ./models/ first — see scripts/download_model.ps1
#
# ── NOTE ──────────────────────────────────────────────────────────────
# This Dockerfile is kept ONLY as a fallback for custom builds (e.g. GPU,
# special quantization).  The default docker-compose.yml uses the pre-built
# image directly — it does NOT build from this file.
# ──────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential cmake curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "llama-cpp-python[server]>=0.3" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

WORKDIR /app
VOLUME ["/models"]
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
    CMD curl -sf http://localhost:8000/v1/models || exit 1

ENV MODEL=/models/model.gguf
ENV MODEL_ALIAS=local
ENV N_CTX=4096
ENV N_THREADS=4
ENV HOST=0.0.0.0

ENTRYPOINT ["sh", "-c", \
    "python -m llama_cpp.server \
        --model $MODEL \
        --model_alias $MODEL_ALIAS \
        --n_ctx $N_CTX \
        --n_threads $N_THREADS \
        --host $HOST"]

