# ─── Local LLM sidecar — llama-cpp-python with OpenAI-compatible API ───
#
# Serves a GGUF model at http://llm:8000/v1 with the same API shape as
# OpenAI (chat/completions, embeddings).
#
# Build:
#   docker compose build llm
#
# Run standalone:
#   docker run --rm -v ./models:/models -p 8080:8000 ai-job-hunter-llm
#
# Pre-download a model into ./models/ first — see scripts/download_model.*

FROM python:3.12-slim

# Build dependencies for llama-cpp-python (if no pre-built wheel is found)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential cmake curl && \
    rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with its built-in OpenAI server
RUN pip install --no-cache-dir \
    "llama-cpp-python[server]>=0.3" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

WORKDIR /app

# Models are bind-mounted at runtime
VOLUME ["/models"]

# llama-cpp-python defaults to port 8000 (--port flag ignored in newer versions)
EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=5 \
    CMD curl -sf http://localhost:8000/v1/models || exit 1

# All settings via env vars — override any of these in docker-compose.yml
ENV MODEL=/models/model.gguf
ENV MODEL_ALIAS=local
ENV N_CTX=4096
ENV N_THREADS=4
ENV HOST=0.0.0.0

# Pure CLI args — stable across llama-cpp-python versions (no config file)
# Note: server listens on port 8000 by default; compose maps 8080→8000
ENTRYPOINT ["sh", "-c", \
    "python -m llama_cpp.server \
        --model $MODEL \
        --model_alias $MODEL_ALIAS \
        --n_ctx $N_CTX \
        --n_threads $N_THREADS \
        --host $HOST"]

