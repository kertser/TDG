# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tdg:tdg_secret@localhost:5432/tdg
DATABASE_URL_SYNC=postgresql://tdg:tdg_secret@localhost:5432/tdg

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / Security ──────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_PASSWORD=admin

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1
OPENAI_MODEL_MINI=gpt-4.1-mini
OPENAI_MODEL_NANO=gpt-4o-mini

# ── Local LLM (optional, for air-gapped deployments) ──
# When OPENAI_API_KEY is empty, the parser uses LOCAL_MODEL_URL
# for an OpenAI-compatible endpoint (e.g. llama.cpp, vLLM, Ollama).
# Start the sidecar: docker compose --profile llm up -d
# LOCAL_MODEL_URL=http://localhost:8081/v1
# LOCAL_MODEL_NAME=local
# LOCAL_TRIAGE_ENABLED=true
# LOCAL_TRIAGE_TIMEOUT=5.0
# Optional llama.cpp tuning for the docker compose llm profile:
# LLM_CTX_SIZE=4096
# LLM_THREADS=8
# LLM_THREADS_BATCH=8
# LLM_BATCH_SIZE=256
# LLM_UBATCH_SIZE=128
# LLM_CACHE_REUSE=64
# LLM_SLOT_PROMPT_SIMILARITY=0.75

# ── Local LLM (triage classification / air-gapped fallback) ──
# Local model handles ONLY simple classification tasks (command vs ack vs report).
# Full order parsing always goes to cloud LLM when OPENAI_API_KEY is set.
# Download model: .\scripts\download_model.ps1
#
# Docker: backend reaches LLM via internal Docker network (service name + internal port).
# Native dev (outside Docker): change to http://localhost:8081/v1
# LOCAL_MODEL_URL=http://tdg-llm:8080/v1
# LOCAL_MODEL_NAME=local
# LOCAL_TRIAGE_ENABLED=true
# LOCAL_TRIAGE_TIMEOUT=5.0
# if triage classifies as "command", it goes to the main parser, otherwise it's dropped or handled as "ack"/"report".
# LOCAL_TRIAGE_TIMEOUT=5.0
# Optional llama.cpp tuning for the docker compose llm profile:
# LLM_CTX_SIZE=4096
# LLM_THREADS=8
# LLM_THREADS_BATCH=8
# LLM_BATCH_SIZE=256
# LLM_UBATCH_SIZE=128
# LLM_CACHE_REUSE=64
# LLM_SLOT_PROMPT_SIMILARITY=0.75

# ── LLM Parsing Mode ─────────────────────────────────
# Controls how radio messages are routed through the parsing pipeline:
#   "llm_first"    — always call LLM; keyword only as fallback (default)
#   "keyword_first" — keyword first; LLM for low-confidence (legacy)
#   "keyword_only"  — no LLM calls at all (offline/testing)
# LLM_PARSING_MODE=llm_first

# ── Docker Compose Profiles ───────────────────────────
# Activates the local LLM container by default for all docker compose commands.
# Remove or comment out this line to run without the LLM sidecar.
COMPOSE_PROFILES=llm

# ── Application ───────────────────────────────────────
APP_NAME=TDG Tactical Decision Game Platform
DEBUG=true
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000","http://127.0.0.1:8000"]

