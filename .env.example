# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tdg:tdg_secret@localhost:5432/tdg
DATABASE_URL_SYNC=postgresql://tdg:tdg_secret@localhost:5432/tdg

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / Security ──────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1

# ── Application ───────────────────────────────────────
APP_NAME=TDG Tactical Decision Game Platform
DEBUG=true
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000","http://127.0.0.1:8000"]

